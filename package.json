{
  "name": "notes",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "open": "node scripts/open-app.js",
    "start": "expo start --go",
    "start:expo": "expo start --go",
    "start:cli": "expo start --dev-client",
    "android": "expo start --android --go",
    "android:expo": "expo start --android --go",
    "android:cli": "expo run:android",
    "ios": "expo start --ios --go",
    "ios:expo": "expo start --ios --go",
    "ios:cli": "expo run:ios",
    "ios:cloud": "eas build -p ios",
    "prebuild": "expo prebuild",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.0",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.17",
    "expo-sharing": "~14.0.7",
    "expo-status-bar": "~3.0.8",
    "expo-system-ui": "~6.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "babel-preset-expo": "^54.0.10",
    "typescript": "~5.9.2"
  }
